# Smart-Lab SV IPB — Environment Variables
# Copy file ini menjadi .env lalu isi dengan kredensial MySQL Anda.
#
# Contoh untuk DBngin (macOS):
#   DB_HOST=127.0.0.1
#   DB_PORT=3306  (atau port yang ditampilkan di DBngin)
#   DB_USER=root
#   DB_PASSWORD=
#   DB_NAME=smartlab_db
#
# Contoh untuk XAMPP (Windows):
#   DB_HOST=127.0.0.1
#   DB_PORT=3306
#   DB_USER=root
#   DB_PASSWORD=
#   DB_NAME=smartlab_db

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=smartlab_db

# Admin API Key (ganti untuk production!)
ADMIN_API_KEY=CHANGE-ME-IN-PRODUCTION
